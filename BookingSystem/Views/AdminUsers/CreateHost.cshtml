@model BookingSystem.ViewModels.AddHostViewModel
@{
    ViewBag.Title = "Add host";
}

<section class="form-card">
    <h1>Add host</h1>

    @using (Html.BeginForm("CreateHost", "AdminUsers", FormMethod.Post, new { novalidate = "novalidate" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

        <div class="form-group">
            @Html.LabelFor(m => m.Username)
            @Html.TextBoxFor(m => m.Username, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.Username, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Password)
            @Html.PasswordFor(m => m.Password, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.ConfirmPassword)
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.FirstName)
            @Html.TextBoxFor(m => m.FirstName, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.LastName)
            @Html.TextBoxFor(m => m.LastName, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Email)
            @Html.TextBoxFor(m => m.Email, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.DateOfBirth)
            @Html.EditorFor(m => m.DateOfBirth, new { htmlAttributes = new { @class = "form-input" } })
            @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Gender)
            @Html.EnumDropDownListFor(m => m.Gender, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "field-error" })
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Add host</button>
            <a class="btn-secondary" href="@Url.Action("Index")">Cancel</a>
        </div>
    }
</section>
