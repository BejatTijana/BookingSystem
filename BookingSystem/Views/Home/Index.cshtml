@model BookingSystem.ViewModels.SearchViewModel
@{
    ViewBag.Title = "Home";
}

@if (TempData["Success"] != null)
{
    <div class="form-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="validation-summary">@TempData["Error"]</div>
}

<div class="hero-banner">
    <span class="hero-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#be123c">
            <path d="M21 16v-2l-8-5V3.5A1.5 1.5 0 0 0 11.5 2 1.5 1.5 0 0 0 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
        </svg>
    </span>
    <h1 class="hero-title">Find your perfect stay</h1>
</div>

<section class="search-bar">
    @using (Html.BeginForm("Index", "Home", FormMethod.Get))
    {
        <div class="search-fields">
            @Html.TextBoxFor(m => m.SearchTerm, new { @class = "form-input", placeholder = "Name" })
            @Html.TextBoxFor(m => m.City, new { @class = "form-input", placeholder = "City" })
            @Html.EnumDropDownListFor(m => m.Type, "All types", new { @class = "form-input" })
            @Html.TextBoxFor(m => m.MinPrice, new { @class = "form-input", type = "number", step = "0.01", placeholder = "Min price" })
            @Html.TextBoxFor(m => m.MaxPrice, new { @class = "form-input", type = "number", step = "0.01", placeholder = "Max price" })
            @Html.DropDownListFor(m => m.SortBy, new SelectList(new[]
            {
                new { Value = "name", Text = "Name" },
                new { Value = "price", Text = "Price" },
                new { Value = "date", Text = "Posting date" }
            }, "Value", "Text", Model.SortBy), "Sort by", new { @class = "form-input" })
            @Html.DropDownListFor(m => m.SortDir, new SelectList(new[]
            {
                new { Value = "asc", Text = "Ascending" },
                new { Value = "desc", Text = "Descending" }
            }, "Value", "Text", Model.SortDir), new { @class = "form-input" })
            <button type="submit" class="btn-primary">Search</button>
        </div>
    }
</section>

@if (Model.Results == null || !Model.Results.Any())
{
    <p class="no-results">No accommodations found.</p>
}
else
{
    <div class="card-grid">
        @foreach (var a in Model.Results)
        {
            var img = string.IsNullOrEmpty(a.Image) ? "placeholder.jpg" : a.Image;
            <div class="acc-card">
                <img class="card-image"
                     src="@Url.Content("~/Content/images/" + img)"
                     alt="@a.Name"
                     onerror="this.onerror=null;this.src='@Url.Content("~/Content/images/placeholder.jpg")';" />
                <div class="card-body">
                    <h3>@a.Name</h3>
                    <p class="card-meta">@a.City &middot; @a.Type</p>
                    <p class="card-price">@a.PricePerNight.ToString("0.00") / night</p>
                    <p class="card-guests">Max guests: @a.MaxGuests</p>
                    <a class="btn-details" href="@Url.Action("Details", "Accommodations", new { id = a.Id })">View details</a>
                </div>
            </div>
        }
    </div>
}
